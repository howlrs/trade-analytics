{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(sui client *)",
      "Bash(sui keytool *)",
      "Bash(suiup *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(node *)",
      "Bash(GCE_PASSPHRASE=$(grep GCE_PASSPHRASE .env | cut -d= -f2) bash *)",
      "Bash(GCE_PASSPHRASE=* bash deploy/logs.sh *)",
      "Bash(gcloud compute ssh *)",
      "Bash(cat * | gemini -p *)",
      "Bash(gemini -p *)",
      "Bash(gemini -m * *)",
      "Bash(git diff * | gemini *)",
      "Bash(bash deploy/pre-deploy-check.sh)",
      "Bash(python3 .claude/tools/screening.py *)",
      "Bash(python3 .claude/tools/watcher.py *)"
    ],
    "deny": [
      "Bash(sui client publish *)",
      "Bash(sui client call *)",
      "Bash(sui client transfer *)",
      "Bash(sui client pay *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/boot-inject.sh",
            "timeout": 10,
            "statusMessage": "Loading LP state..."
          }
        ]
      }
    ]
  }
}
