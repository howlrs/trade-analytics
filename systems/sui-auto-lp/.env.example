# Sui Network: mainnet | testnet
SUI_NETWORK=testnet

# Private key (base64 encoded or suiprivkey bech32) - NEVER commit this
SUI_PRIVATE_KEY=

# Cetus pool IDs to manage (comma separated)
POOL_IDS=

# Rebalance threshold - trigger when price is within X% of range edge
REBALANCE_THRESHOLD=0.03

# Check interval in seconds (rebalance evaluation frequency)
CHECK_INTERVAL=60

# Harvest interval in seconds (claim fees + rewards to wallet)
HARVEST_INTERVAL=3600

# Max slippage tolerance for swaps
SLIPPAGE_TOLERANCE=0.01

# Minimum gas-to-profit ratio (skip if fees < ratio * gas)
MIN_GAS_PROFIT_RATIO=2

# Minimum fee accrual in USD before harvesting
HARVEST_THRESHOLD_USD=0.50

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Max swap cost as fraction of position value (swap fee guard)
MAX_SWAP_COST_PCT=0.01

# Swap-free rebalance: skip swap during rebalance (true = no swap)
SWAP_FREE_REBALANCE=true

# Allow small swaps in swap-free mode to fix ratio mismatch (0 = disabled, 0.10 = up to 10%)
SWAP_FREE_MAX_RATIO_SWAP=0.10

# Dry-run mode: set to false to execute real transactions
DRY_RUN=true

# Pause bot without stopping the service (true = skip all checks)
PAUSED=false

# DeepBook Margin Manager IDs (comma separated, optional - auto-discovered from tx history)
# DEEPBOOK_MARGIN_MANAGER_IDS=0x...

# GCE SSH passphrase (for deploy script)
GCE_PASSPHRASE=dddd
